  // ─── 2. ACTIVITY METRICS ────────────────────────────────────────────────
    // Counts commits per week (last 12 weeks) to measure recent activity.
    public Map<String, Integer> getWeeklyActivity(Repository repository) {
        Map<String, Integer> weeklyMap = new LinkedHashMap<>();
        DateTimeFormatter fmt = DateTimeFormatter.ofPattern("yyyy-MM-dd");

        // Build 12 week buckets (most recent first)
        LocalDate today = LocalDate.now();
        List<String> weeks = new ArrayList<>();
        for (int i = 11; i >= 0; i--) {
            LocalDate weekStart = today.minusWeeks(i);
            weeks.add(weekStart.format(fmt));
            weeklyMap.put(weekStart.format(fmt), 0);
        }

        for (Commit commit : repository.getCommits()) {
            try {
                // GitHub date format: "2024-04-01T12:34:56Z"
                String dateStr = commit.getDate().substring(0, 10);
                LocalDate commitDate = LocalDate.parse(dateStr, fmt);

                // Find which bucket this commit falls into
                for (int i = 0; i < weeks.size(); i++) {
                    LocalDate bucketStart = LocalDate.parse(weeks.get(i), fmt);
                    LocalDate bucketEnd = (i + 1 < weeks.size())
                            ? LocalDate.parse(weeks.get(i + 1), fmt)
                            : today.plusDays(1);

                    if (!commitDate.isBefore(bucketStart) && commitDate.isBefore(bucketEnd)) {
                        weeklyMap.put(weeks.get(i), weeklyMap.get(weeks.get(i)) + 1);
                        break;
                    }
                }
            } catch (Exception ignored) {}
        }
        return weeklyMap;
    }

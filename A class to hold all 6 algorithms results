package com.gitpulse.algorithm;

import com.gitpulse.model.Contributor;
import java.util.List;
import java.util.Map;

// A plain data container — holds everything the algorithm computed.
public class AlgorithmResult {
    private final List<Contributor> topContributors;
    private final Map<String, Integer> weeklyActivity;
    private final Map<String, Double> contributorScores;
    private final String balanceWarning;

    public AlgorithmResult(List<Contributor> topContributors,
                           Map<String, Integer> weeklyActivity,
                           Map<String, Double> contributorScores,
                           String balanceWarning) {
        this.topContributors  = topContributors;
        this.weeklyActivity   = weeklyActivity;
        this.contributorScores = contributorScores;
        this.balanceWarning   = balanceWarning;
    }

    public List<Contributor> getTopContributors()       { return topContributors; }
    public Map<String, Integer> getWeeklyActivity()     { return weeklyActivity; }
    public Map<String, Double> getContributorScores()   { return contributorScores; }
    public String getBalanceWarning()                   { return balanceWarning; }

    @Override
    public String toString() {
        StringBuilder sb = new StringBuilder();
        sb.append("=== Algorithm Results ===\n");
        sb.append("Balance: ").append(balanceWarning).append("\n");
        sb.append("Top Contributors:\n");
        for (Contributor c : topContributors) {
            sb.append("  ").append(c.getUsername())
              .append(" — ").append(c.getTotalCommits()).append(" commits")
              .append(" (").append(c.getCommitShare()).append("%)")
              .append(" score=").append(contributorScores.getOrDefault(c.getUsername(), 0.0))
              .append("\n");
        }
        return sb.toString();
    }
}
